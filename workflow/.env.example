# ============================================
# DAPPS Bot - Variables de Entorno
# ============================================
# Copia este archivo como .env y completa los valores.
#   cp .env.example .env

# --- Azure App Registration ---
MICROSOFT_APP_ID=e5ac961e-46a9-47df-870a-4b874d4e6188
MICROSOFT_APP_PASSWORD=<TU_CLIENT_SECRET_AQUÍ>

# --- Canal de Teams destino ---
TEAMS_CHANNEL_ID=19:5ba87851da9549b7a6b2f31e85f4cdb8@thread.tacv2
TEAMS_TEAM_ID=ae0a0280-5e3e-4f89-8a0a-2aa9c9c5f0e1
TENANT_ID=cddbd103-c38e-4f8c-92db-b28549147502

# --- Bot Framework Service URL (región Americas) ---
SERVICE_URL=https://smba.trafficmanager.net/amer/

# --- n8n Integration ---
# Webhook URL para procesar mensajes 1:1 (workflow personal-intake)
N8N_PERSONAL_WEBHOOK_URL=https://special-lamp-xqwjww99xqxcp7r4-5678.app.github.dev/webhook/personal-intake

# --- Azure Blob Storage (archivos Excel / PDF + metadata.json) ---
# Connection string del Storage Account (ver Roadmap paso 1)
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<TU_STORAGE_ACCOUNT>;AccountKey=<TU_KEY>;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER=requerimientos

# --- Azure AI Document Intelligence (análisis de Excel / PDF) ---
# Endpoint y key del recurso Document Intelligence (ver Roadmap paso 2)
DOC_INTELLIGENCE_ENDPOINT=https://<TU_REGION>.cognitiveservices.azure.com/
DOC_INTELLIGENCE_KEY=<TU_DOC_INTELLIGENCE_KEY>

# --- Microsoft Planner (Graph API — usa las mismas credenciales del bot) ---
# Plan ID y Bucket ID del Planner (se obtienen de Graph Explorer o la URL del plan)
PLANNER_PLAN_ID=LY1tOr8SKUqBNay8KAUlmmUAH3Ss
PLANNER_BUCKET_ID=yD84QLz5yUufFD50vAQvj2UAI0gy

# --- Puerto del servidor ---
PORT=3978
